# =============================================================================
# Backend environment variables
# =============================================================================

# PostgreSQL connection string.
# Local format:      postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Neon (recommended free): copy the "Pooled connection" string from your Neon dashboard.
# Render Postgres:   set automatically by Render when you attach a database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/khushal_agency?schema=public"

# Express server port.
# Local development: 4000.
# Render:            leave unset — Render injects PORT automatically. The app
#                    falls back to 4000 if no PORT is provided.
PORT=4000

# Allowed CORS origin(s). Single origin or comma-separated list.
# Local development: http://localhost:5173 (Vite dev server)
# Production:        the deployed frontend URL(s), e.g.:
#   CORS_ORIGIN=https://khushalautomation.com,https://khushal-automation-agency.vercel.app
CORS_ORIGIN=http://localhost:5173

# Node environment. Set to "production" on Render.
NODE_ENV=development

# =============================================================================
# Backend environment variables
# =============================================================================

# PostgreSQL connection string.
# Local format:      postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Neon (recommended free): copy the "Pooled connection" string from your Neon dashboard.
# Render Postgres:   set automatically by Render when you attach a database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/khushal_agency?schema=public"

# Express server port.
# Local development: 4000.
# Render:            leave unset — Render injects PORT automatically. The app
#                    falls back to 4000 if no PORT is provided.
PORT=4000

# Allowed CORS origin(s). Single origin or comma-separated list.
# Local development: http://localhost:5173 (Vite dev server)
# Production:        the deployed frontend URL(s), e.g.:
#   CORS_ORIGIN=https://khushalautomation.com,https://khushal-automation-agency.vercel.app
CORS_ORIGIN=http://localhost:5173

# Node environment. Set to "production" on Render.
NODE_ENV=development

# Resend API key for "new lead" email notifications. Optional —
# leaving this unset disables emails (server still works, leads still save).
# Get a key from https://resend.com → API Keys.
RESEND_API_KEY=

# Inbox that receives lead notifications. While using Resend's shared
# onboarding@resend.dev sender, this MUST be the email you signed up to
# Resend with — Resend won't deliver to other addresses until you verify a domain.
LEADS_NOTIFICATION_TO=khushalchandpa7@gmail.com

# Sender address. Default uses Resend's shared domain — works immediately,
# no DNS config needed. Once you verify your own domain on Resend you can
# switch to e.g. "Khushal Automation <noreply@khushalautomation.com>".
LEADS_NOTIFICATION_FROM=Khushal Automation <onboarding@resend.dev>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(uuid())
  name       String
  email      String
  company    String?
  painPoints String
  status     String   @default("NEW")
  createdAt  DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model PortfolioProject {
  id          String   @id @default(uuid())
  title       String
  description String
  metrics     String
  toolsUsed   String[]
}

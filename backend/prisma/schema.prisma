generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                    String   @id @default(uuid())
  name                  String
  email                 String
  company               String?
  painPoints            String
  status                String   @default("NEW")
  sourceSection         String?
  selectedPainPoint     String?
  roiMonthlyLoss        Int?
  roiPayload            Json?
  quizAnswers           Json?
  recommendedAutomation String?
  leadScore             Int      @default(0)
  utmCampaign           Json?
  createdAt             DateTime @default(now())

  @@index([status])
  @@index([leadScore])
  @@index([createdAt])
}

model PortfolioProject {
  id          String   @id @default(uuid())
  title       String
  description String
  metrics     String
  toolsUsed   String[]
}

# =============================================================================
# Frontend environment variables (Vite — must be prefixed VITE_ to be exposed)
# =============================================================================

# Backend API base URL.
# Local development: http://localhost:4000
# Production:        the deployed Render backend URL, e.g.:
#   VITE_API_URL=https://khushal-automation-agency-api.onrender.com
VITE_API_URL=http://localhost:4000
